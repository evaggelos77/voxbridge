OPENAI_API_KEY=PASTE_YOUR_KEY_HERE
OPENAI_TTS_VOICE=cedar
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSLATE_MODEL=gpt-5-mini

# --- Online Call invite links (optional) ---
# If you run the server behind a public domain or tunnel (e.g. https://yourdomain.com),
# set this so invite links don't use 127.0.0.1.
# Example:
#   PUBLIC_BASE_URL=https://yourdomain.com
PUBLIC_BASE_URL=

# --- Auth (recommended) ---
SESSION_SECRET=change-me-to-a-long-random-string

# --- Google OAuth (optional) ---
# Create OAuth Client (Web application) in Google Cloud Console.
# Authorized redirect URI example:
#   http://127.0.0.1:8000/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/auth/google/callback
