# VoxBridge production environment
# Συμπλήρωσε τα παρακάτω πριν/κατά το install.sh

OPENAI_API_KEY=PASTE_YOUR_KEY_HERE

# Models / voice (optional)
OPENAI_TTS_VOICE=cedar
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TRANSLATE_MODEL=gpt-5-mini

# IMPORTANT: must be https://intervoxai.com (χωρίς /app)
PUBLIC_BASE_URL=https://intervoxai.com

# Session cookie signing secret (θα δημιουργηθεί αυτόματα αν το αφήσεις κενό)
SESSION_SECRET=
